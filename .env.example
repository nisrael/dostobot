AUTH_USERNAME=admin
# Generate a bcrypt hash (cost 12) for your password:
#   docker run --rm -it alpine sh -c 'apk add --no-cache apache2-utils && htpasswd -bnBC 12 "" yourpassword | tr -d ":\n"'
# Then paste the result here (no surrounding quotes needed)
AUTH_PASSWORD_HASH=

# Your music library directory on the host
MUSIC_DIR=/path/to/your/music

# Domain name Traefik routes to this service
TRAEFIK_HOST=dostobot.example.com

# Traefik certificate resolver name (matches your Traefik config)
CERT_RESOLVER=letsencrypt
