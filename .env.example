# Domain name Traefik routes to this service
PUBLIC_HOST=dostobot.example.com

# Domain name of your authentik instance (used to build the forwardauth URL)
# e.g. auth.example.com  →  https://auth.example.com/outpost.goauthentik.io/auth/traefik
AUTHENTIK_HOST=auth.example.com

# Your music library directory on the host
MUSIC_DIR=/path/to/your/music

# Traefik certificate resolver name (matches your Traefik config)
CERT_RESOLVER=letsencrypt
